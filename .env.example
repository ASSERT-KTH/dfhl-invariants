# Dwellir RPC endpoints — get your API key at https://dashboard.dwellir.com
# Copy this file to .env and replace YOUR_API_KEY with your Dwellir key.

MAINNET_RPC_URL=https://api-ethereum-mainnet.n.dwellir.com/YOUR_API_KEY
BLAST_RPC_URL=https://api-blast-mainnet-archive.n.dwellir.com/YOUR_API_KEY
