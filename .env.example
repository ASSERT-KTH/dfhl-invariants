ARBITRUM_RPC_URL=https://api-arbitrum-mainnet-archive.n.dwellir.com/YOUR_API_KEY
BSC_RPC_URL=https://api-bsc-mainnet-full.n.dwellir.com/YOUR_API_KEY
MOONRIVER_RPC_URL=https://moonriver.public.blastapi.io
GNOSIS_RPC_URL=https://api-gnosis-mainnet.n.dwellir.com/YOUR_API_KEY
